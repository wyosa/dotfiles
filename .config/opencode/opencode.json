{
  "$schema": "https://opencode.ai/config.json",
  // === Model ===
  "model": "openai/gpt-5.4",
  // === Agents ===
  "agent": {
    "ask": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    }
  },
  "autoupdate": true,
  // === MCP ===
  "mcp": {
    // docs lookup for libraries
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    // dynamic and reflective problem-solving through a structured thinking process
    "server-sequential-thinking": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    // allows LLMs to interact with web pages through structured accessibility snapshots
    "playwright": {
      "type": "local",
      "command": ["bunx", "@playwright/mcp@latest"],
      "enabled": true
    },
    // shadcn/ui mcp
    "shadcn": {
      "type": "local",
      "command": ["bunx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    // ai-optimized postgres expertise
    "pg-aiguide": {
      "type": "remote",
      "url": "https://mcp.tigerdata.com/docs",
      "enabled": true,
    },
  }
}
